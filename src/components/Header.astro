---
import { SITE } from "../config";

const currentPath = Astro.url.pathname;
const activeLabel = currentPath === "/" ? "/home" : currentPath;
const host = new URL(SITE.siteUrl).host;
---

<header class="site-header runtime-strip">
  <div class="runtime-grid">
    <div class="runtime-row">
      <span class="runtime-label">SYS.NAME</span>
      <a class="brand" href="/">
        <span class="brand-mark">D</span>
        <span class="runtime-value">DEVKORIEL_BLOG</span>
      </a>
    </div>
    <div class="runtime-row">
      <span class="runtime-label">SYS.AUTH</span>
      <span class="runtime-value is-accent">PUBLIC_READ</span>
    </div>
    <div class="runtime-row">
      <span class="runtime-label">SYS.NODE</span>
      <span class="runtime-value">{host}</span>
    </div>
  </div>

  <div class="runtime-grid runtime-grid-right">
    <div class="runtime-row runtime-row-right">
      <span class="runtime-label">ACTIVE</span>
      <span class="runtime-value">{activeLabel}</span>
    </div>
    <div class="runtime-row runtime-row-right">
      <span class="runtime-label">AUTHOR</span>
      <span class="runtime-value">{SITE.author}</span>
    </div>
    <div class="runtime-row runtime-row-right">
      <span class="runtime-label">STATUS</span>
      <span class="runtime-value is-orange">CONTENT_LIVE</span>
    </div>
  </div>

  <nav class="nav-shell" aria-label="Primary navigation">
    <span class="module-prefix">root@nimdal/nav &gt; select module</span>
    <ul class="nav-list">
      {SITE.navigation.map(item => {
        const isActive =
          item.href === "/"
            ? currentPath === "/"
            : currentPath.startsWith(item.href);

        return (
          <li>
            <a
              class:list={["nav-link", { active: isActive }]}
              aria-current={isActive ? "page" : undefined}
              href={item.href}
            >
              {isActive ? `> ${item.label}` : item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
