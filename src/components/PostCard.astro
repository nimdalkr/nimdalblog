---
interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
}

const { href, title, description, pubDate, tags } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("ko-KR", {
  year: "numeric",
  month: "short",
  day: "numeric"
}).format(pubDate);
---

<article class="post-card">
  <div class="post-meta">
    <p class="eyebrow">[{formattedDate}]</p>
    <span class="post-status">published</span>
  </div>
  <h3>
    <a class="post-link" href={href}>{title}</a>
  </h3>
  <p class="post-description">{description}</p>
  <ul class="tag-list" aria-label="Tags">
    {tags.map(tag => <li>{tag}</li>)}
  </ul>
</article>
