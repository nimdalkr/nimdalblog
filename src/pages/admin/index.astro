---
const title = "nimdal control plane";
const asciiLogo = ` _   _ ___ __  __ ____    _    _     
| \\ | |_ _|  \\/  |  _ \\  / \\  | |    
|  \\| || || |\\/| | | | |/ _ \\ | |    
| |\\  || || |  | | |_| / ___ \\| |___ 
|_| \\_|___|_|  |_|____/_/   \\_\\_____|`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <link href="/admin/config.yml" type="text/yaml" rel="cms-config-url" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark;
        --font-primary: "Geist Variable", "Geist Mono", "Courier New", monospace;
        --bg: #0f1210;
        --surface: #161a15;
        --fg: #d4d8d0;
        --dim: #5a6058;
        --accent: #4ade80;
        --accent-border: #2a5c38;
        --orange: #e8854a;
        --border: #2a2e28;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font-primary);
      }

      body::before,
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
      }

      body::before {
        z-index: 2;
        opacity: 0.05;
        background: repeating-linear-gradient(
          to bottom,
          rgba(212, 216, 208, 1) 0,
          rgba(212, 216, 208, 1) 1px,
          transparent 1px,
          transparent 4px
        );
      }

      body::after {
        z-index: 1;
        background: radial-gradient(circle at center, transparent 58%, rgba(0, 0, 0, 0.44) 100%);
      }

      .admin-page-shell {
        position: relative;
        z-index: 3;
        min-height: 100vh;
        padding: 20px 24px;
      }

      .admin-terminal {
        width: min(100%, 1240px);
        min-height: calc(100vh - 40px);
        margin: 0 auto;
        border: 1px solid var(--border);
        background: rgba(15, 18, 16, 0.92);
      }

      .admin-runtime {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 24px;
        padding: 16px 24px 10px;
        border-bottom: 1px solid var(--border);
      }

      .admin-grid {
        display: grid;
        gap: 2px;
      }

      .admin-grid-right {
        justify-items: end;
      }

      .admin-row {
        display: flex;
        align-items: center;
        gap: 12px;
        min-height: 22px;
      }

      .admin-row-right {
        justify-content: flex-end;
      }

      .admin-label {
        min-width: 76px;
        color: var(--dim);
      }

      .admin-value {
        color: var(--fg);
      }

      .admin-value.is-accent {
        color: var(--accent);
      }

      .admin-main {
        display: grid;
        grid-template-columns: minmax(300px, 420px) minmax(0, 1fr);
        gap: 24px;
        padding: 18px 24px 24px;
      }

      .admin-intro,
      .admin-root {
        min-height: 0;
        border: 1px solid var(--border);
        background: rgba(22, 26, 21, 0.78);
      }

      .admin-intro {
        display: grid;
        align-content: start;
        gap: 14px;
        padding: 18px;
      }

      .admin-root {
        overflow: hidden;
      }

      #nc-root {
        min-height: 100%;
      }

      .admin-prompt,
      .admin-copy,
      .admin-note,
      .admin-list {
        margin: 0;
      }

      .admin-prompt {
        color: var(--accent);
      }

      .admin-note {
        color: var(--dim);
      }

      .admin-list {
        padding-left: 18px;
      }

      .admin-list li + li {
        margin-top: 8px;
      }

      .admin-ascii {
        margin: 0;
        color: var(--fg);
        font-size: 10px;
        line-height: 1.14;
        white-space: pre;
      }

      @media (max-width: 900px) {
        .admin-runtime,
        .admin-main {
          grid-template-columns: 1fr;
        }

        .admin-grid-right {
          justify-items: start;
        }

        .admin-row-right {
          justify-content: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <div class="admin-page-shell">
      <div class="admin-terminal">
        <header class="admin-runtime">
          <div class="admin-grid">
            <div class="admin-row">
              <span class="admin-label">SYS.NAME</span>
              <span class="admin-value">NIMDAL_CMS</span>
            </div>
            <div class="admin-row">
              <span class="admin-label">SYS.AUTH</span>
              <span class="admin-value is-accent">GITHUB_OAUTH</span>
            </div>
            <div class="admin-row">
              <span class="admin-label">SYS.NODE</span>
              <span class="admin-value">blog.nimdal.xyz/admin</span>
            </div>
          </div>
          <div class="admin-grid admin-grid-right">
            <div class="admin-row admin-row-right">
              <span class="admin-label">MODE</span>
              <span class="admin-value">EDITORIAL_FLOW</span>
            </div>
            <div class="admin-row admin-row-right">
              <span class="admin-label">TARGET</span>
              <span class="admin-value">src/content/posts</span>
            </div>
            <div class="admin-row admin-row-right">
              <span class="admin-label">STATE</span>
              <span class="admin-value is-accent">READY_FOR_LOGIN</span>
            </div>
          </div>
        </header>

        <main class="admin-main">
          <aside class="admin-intro">
            <pre class="admin-ascii">{asciiLogo}</pre>
            <p class="admin-prompt">$ auth/login --provider github</p>
            <p class="admin-copy">
              Editorial control plane for writing, media uploads, and publishing new markdown
              posts without touching the CLI.
            </p>
            <p class="admin-note">
              After authentication, content is committed directly into the repository through the
              configured GitHub backend.
            </p>
            <ul class="admin-list">
              <li>create and edit posts from the browser</li>
              <li>upload images to `public/uploads`</li>
              <li>save drafts and publish through git commits</li>
            </ul>
          </aside>

          <section class="admin-root">
            <div id="nc-root"></div>
          </section>
        </main>
      </div>
    </div>

    <script is:inline>
      window.CMS_MANUAL_INIT = true;
    </script>
    <script src="https://unpkg.com/decap-cms@^3.10.0/dist/decap-cms.js"></script>
    <script is:inline>
      window.CMS.init();
    </script>
  </body>
</html>
