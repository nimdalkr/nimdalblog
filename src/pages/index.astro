---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { SITE } from "../config";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPosts = posts.filter(post => post.data.featured).slice(0, 2);
const recentPosts = posts.slice(0, 4);
const asciiLogo = ` _   _ ___ __  __ ____    _    _     
| \\ | |_ _|  \\/  |  _ \\  / \\  | |    
|  \\| || || |\\/| | | | |/ _ \\ | |    
| |\\  || || |  | | |_| / ___ \\| |___ 
|_| \\_|___|_|  |_|____/_/   \\_\\_____|`;
---

<BaseLayout title={`${SITE.title} | Home`} description={SITE.description}>
  <section class="hero terminal-panel">
    <div class="hero-copy">
      <p class="prompt-line">$ cat /etc/nimdal</p>
      <pre class="ascii-name">{asciiLogo}</pre>
      <div class="terminal-copy">
        <p class="hero-text">{SITE.intro}</p>
        <p class="helper-copy">
          A terminal-toned writing space for personal engineering notes, operating decisions, and
          lessons that are worth keeping after the release cycle ends.
        </p>
      </div>
      <ul class="hero-points" aria-label="Core principles">
        <li>Favor reusable decisions over one-off commentary.</li>
        <li>Explain operations and implementation details before tooling hype.</li>
        <li>Keep writing concise, direct, and easy to scan.</li>
      </ul>
      <div class="hero-actions">
        <a class="button primary" href="/posts">open logs</a>
        <a class="button secondary" href="/about">read system note</a>
      </div>
    </div>

    <aside class="hero-panel">
      <p class="resume-title">// runtime</p>
      <div class="status-table">
        <div class="status-row">
          <span class="status-key">location</span>
          <span class="status-value">{SITE.location}</span>
        </div>
        <div class="status-row">
          <span class="status-key">audience</span>
          <span class="status-value">developers / technical teams</span>
        </div>
        <div class="status-row">
          <span class="status-key">delivery</span>
          <span class="status-value">static output + cms publishing</span>
        </div>
        <div class="status-row">
          <span class="status-key">editor</span>
          <span class="status-value">/admin :: decap control plane</span>
        </div>
      </div>
      <a class="signal-badge" href="/admin">
        <span class="signal-dot" aria-hidden="true">
          *
        </span>
        CMS CONTROL -- OPEN PANEL
      </a>
    </aside>
  </section>

  <section class="section-block terminal-panel">
    <p class="prompt-line">$ ls ./foundations</p>
    <div class="section-heading">
      <p class="eyebrow">foundations</p>
      <h2>What this log optimizes for</h2>
    </div>
    <div class="rule-grid">
      <article class="rule-card">
        <h3>Consistency</h3>
        <p>Use token-based spacing, typography, and state rules so every page feels related.</p>
      </article>
      <article class="rule-card">
        <h3>Accessibility</h3>
        <p>Keep strong focus states, stable contrast, and keyboard-first interactions as defaults.</p>
      </article>
      <article class="rule-card">
        <h3>Fast delivery</h3>
        <p>Rely on static generation and simple components to keep publishing fast.</p>
      </article>
    </div>
  </section>

  <section class="section-block terminal-panel">
    <p class="prompt-line">$ ls ./topics</p>
    <div class="section-heading">
      <p class="eyebrow">topics</p>
      <h2>Core topics</h2>
    </div>
    <ul class="topic-grid">
      {SITE.featuredTopics.map(topic => <li>{topic}</li>)}
    </ul>
  </section>

  <section class="section-block terminal-panel">
    <p class="prompt-line">$ ls ./featured</p>
    <div class="section-heading">
      <p class="eyebrow">featured</p>
      <h2>Start here</h2>
    </div>
    <div class="post-grid">
      {featuredPosts.map(post => (
        <PostCard
          href={`/posts/${post.slug}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>

  <section class="section-block terminal-panel">
    <p class="prompt-line">$ tail -n 4 ./recent</p>
    <div class="section-heading">
      <p class="eyebrow">recent</p>
      <h2>Latest posts</h2>
    </div>
    <div class="post-grid">
      {recentPosts.map(post => (
        <PostCard
          href={`/posts/${post.slug}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
