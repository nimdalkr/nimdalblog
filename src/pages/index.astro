---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { SITE } from "../config";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPosts = posts.filter(post => post.data.featured).slice(0, 2);
const recentPosts = posts.slice(0, 4);
---

<BaseLayout title={`${SITE.title} | Home`} description={SITE.description}>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Implementation-ready engineering notes</p>
      <h1>Clean signals for developers and technical teams.</h1>
      <p class="hero-text">{SITE.intro}</p>
      <ul class="hero-points" aria-label="Core principles">
        <li>Favor reusable decisions over one-off commentary.</li>
        <li>Explain operations and implementation details before tooling hype.</li>
        <li>Keep writing concise, direct, and easy to scan.</li>
      </ul>
      <div class="hero-actions">
        <a class="button primary" href="/posts">Read posts</a>
        <a class="button secondary" href="/about">About the site</a>
      </div>
    </div>

    <aside class="hero-panel">
      <p class="panel-label">Site snapshot</p>
      <dl class="snapshot-grid">
        <div>
          <dt>Based in</dt>
          <dd>{SITE.location}</dd>
        </div>
        <div>
          <dt>Writing about</dt>
          <dd>Infra, tooling, product notes</dd>
        </div>
        <div>
          <dt>Audience</dt>
          <dd>Developers and technical teams</dd>
        </div>
        <div>
          <dt>Format</dt>
          <dd>Content-first, searchable, static delivery</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Foundations</p>
      <h2>What this blog optimizes for</h2>
    </div>
    <div class="rule-grid">
      <article class="rule-card">
        <h3>Consistency</h3>
        <p>Use token-based spacing, typography, and state rules so every page feels related.</p>
      </article>
      <article class="rule-card">
        <h3>Accessibility</h3>
        <p>Keep strong focus states, stable contrast, and keyboard-first interactions as defaults.</p>
      </article>
      <article class="rule-card">
        <h3>Fast delivery</h3>
        <p>Rely on static generation and simple components to keep publishing fast.</p>
      </article>
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Topics</p>
      <h2>Core topics</h2>
    </div>
    <ul class="topic-grid">
      {SITE.featuredTopics.map(topic => <li>{topic}</li>)}
    </ul>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Featured</p>
      <h2>Start here</h2>
    </div>
    <div class="post-grid">
      {featuredPosts.map(post => (
        <PostCard
          href={`/posts/${post.slug}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Recent</p>
      <h2>Latest posts</h2>
    </div>
    <div class="post-grid">
      {recentPosts.map(post => (
        <PostCard
          href={`/posts/${post.slug}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
