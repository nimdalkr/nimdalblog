---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../config";
---

<BaseLayout title={`About | ${SITE.title}`} description="About this blog">
  <section class="content-page terminal-panel">
    <p class="prompt-line">$ cat about.md</p>
    <p class="eyebrow">about this blog</p>
    <h1>nimdal / 탁찬우</h1>
    <p>
      This is a personal engineering blog run by nimdal. The goal is to keep technical writing direct,
      easy to maintain, and practical enough to be useful later.
    </p>
    <p>
      The visual system borrows the terminal-like atmosphere from `nimdal.xyz`, but the content and
      identity here are specific to this site. It is meant to document software work, experiments,
      and operational notes without copying another person's profile or editorial voice.
    </p>

    <div class="note-panel">
      <h2>Site notes</h2>
      <ul>
        <li>Brand metadata lives in `src/config.ts`.</li>
        <li>Add Markdown files in `src/content/posts` to publish new static pages.</li>
        <li>Use `/admin` for browser-based writing, media upload, and publishing.</li>
      </ul>
    </div>
  </section>
</BaseLayout>
